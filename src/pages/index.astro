---
import BottomCTA from '../components/BottomCTA.astro';
const navLinks = [
  { href: "/services", label: "Services" },
  { href: "/portfolio", label: "Portfolio" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>Shockwave Studios | Social Media Marketing in Melbourne, FL</title>
  <meta name="description" content="Shockwave Studios is a social media marketing agency in Melbourne, Florida offering content, video production, and automation services." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="site-header">
    <a href="/" class="logo-link" aria-label="Shockwave Studios home">
      <img src="/shockwave-studios/logo.svg" alt="Shockwave Studios" class="logo-img" />
    </a>
    <nav class="nav">
      <button class="nav-toggle" aria-label="Toggle menu" onclick="document.querySelector('.nav-links').classList.toggle('open')">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav-links">
        <li class="has-dropdown">
          <a href="/services">Services</a>
          <ul class="dropdown">
            <li><a href="/services">Social Media Management</a></li>
            <li><a href="/videography">Videography</a></li>
          </ul>
        </li>
        <li><a href="/portfolio">Portfolio</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-glow"></div>
        <p class="eyebrow">Melbourne, Florida</p>
        <h1>Make Social Media Your <span class="highlight">#1 Source of Leads</span>.</h1>
        <p class="subheadline">We handle the content, strategy, and automation so your social media works for you around the clock.</p>
        <a href="https://calendly.com/shockwavestudios-co/30min" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Book a Free Call</a>
      </div>
    </section>

    <section class="our-work-section">
      <h2>Our Work</h2>
      <div class="our-work-grid">
        <div class="work-item">
          <video autoplay muted loop playsinline>
            <source src="/videos/video-1.mp4" type="video/mp4" />
          </video>
          <p class="work-label">Speaker Event Edit</p>
        </div>
        <div class="work-item">
          <video autoplay muted loop playsinline>
            <source src="/videos/video-2.mp4" type="video/mp4" />
          </video>
          <p class="work-label">Event Recap</p>
        </div>
        <div class="work-item">
          <video autoplay muted loop playsinline>
            <source src="/videos/video-3.mp4" type="video/mp4" />
          </video>
          <p class="work-label">Premium Listing Video</p>
        </div>
      </div>
    </section>

    <section class="services-section">
      <h2>What We Do</h2>
      <p class="services-subheader">Every client starts with the same foundation.</p>
      <div class="card-grid">
        <div class="card">
          <svg class="card-icon" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          <h3>Strategy & Content Pillars</h3>
          <p>Every account we manage starts with a plan. We audit your profile first, bio, highlights, link, profile photo, and make sure it's set up to convert visitors into followers and followers into customers. Then we figure out who you're talking to, what they care about, and what kind of content makes them stop scrolling. From there we build a repeatable content system so your page always has a direction, not just random posts.</p>
        </div>
        <div class="card">
          <svg class="card-icon" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
          <h3>On-Site Filming & Production</h3>
          <p>We show up. Whether it's a daily session, a big event, or a product shoot, we handle the camera so you don't have to. Real locations, real people, real moments. Shot to perform on social, not just to look pretty.</p>
        </div>
        <div class="card">
          <svg class="card-icon" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <h3>Editing & Scheduling</h3>
          <p>Raw footage becomes polished Reels, stories, and posts, edited for your brand, captioned for your audience, and scheduled so your page stays consistent without you lifting a finger.</p>
        </div>
        <div class="card">
          <svg class="card-icon" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          <h3>Automated DM Flows</h3>
          <p>We set up systems that turn your comments and DMs into leads automatically. Someone comments on your Reel, they get a message. They ask about pricing, they get a response. It runs 24/7 so you never miss a lead while you're busy running your business.</p>
        </div>
      </div>
    </section>

    <section class="results-section">
      <h2>Results That Speak for Themselves</h2>
      <div class="stat-grid">
        <div class="stat-card">
          <p class="stat-number">82,000</p>
          <p class="stat-unit">Views</p>
          <p class="stat-label">Organic reach, zero ad spend.</p>
        </div>
        <div class="stat-card">
          <p class="stat-number">6,000 Interactions</p>
          <p class="stat-label">Likes, comments, and shares.</p>
        </div>
        <div class="stat-card">
          <p class="stat-number">40 New Leads</p>
          <p class="stat-label">Generated organically.</p>
        </div>
      </div>
      <p class="results-note">Results from the first 3 months working with a client.</p>
    </section>
    <BottomCTA text="Your next client is already scrolling. Let's make sure they stop on you." />
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <a href="/" class="logo-link" aria-label="Shockwave Studios home">
        <img src="/shockwave-studios/logo.svg" alt="Shockwave Studios" class="footer-logo-img" />
      </a>
      <ul class="nav-links footer-links">
        {navLinks.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>
    <p class="copyright">&copy; {new Date().getFullYear()} Shockwave Studios. Melbourne, Florida.</p>
  </footer>

  <style>
    :root {
      --bg: #F4F7FC;
      --bg-secondary: #FFFFFF;
      --accent: #A8C5F0;
      --primary: #1B3A6B;
      --secondary: #5B8FD4;
      --text: #1A1A2E;
    }

    @font-face {
      font-family: 'Monument Extended';
      src: url('/fonts/MonumentExtended-Regular.otf') format('opentype');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }

    @font-face {
      font-family: 'Monument Extended';
      src: url('/fonts/MonumentExtended-Ultrabold.otf') format('opentype');
      font-weight: 800;
      font-style: normal;
      font-display: swap;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      scroll-behavior: smooth;
    }

    a { color: inherit; text-decoration: none; }

    h1, h2, h3 {
      font-family: 'Monument Extended', sans-serif;
      font-weight: 800;
      letter-spacing: 0.02em;
      color: #6B9FD4;
    }

    .eyebrow, .subheadline, .badge, .case-type, .comparison-group-label, th {
      font-family: 'Playfair Display', serif;
    }

    img, video { max-width: 100%; display: block; }

    .site-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 5%;
      height: 88px;
      background: var(--bg);
      position: sticky;
      top: 0;
      z-index: 100;
      border-bottom: 1px solid rgba(168, 197, 240, 0.1);
    }

    .logo {
      font-size: 1.4rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--text);
    }

    .logo-link {
      display: flex;
      align-items: center;
      height: 100%;
      overflow: hidden;
    }

    .logo-img {
      height: 192px;
      width: auto;
      display: block;
    }

    .footer-logo-img {
      height: 160px;
      width: auto;
      display: block;
    }

    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }

    .nav-links a {
      font-weight: 500;
      font-size: 0.95rem;
      transition: color 0.2s ease;
    }

    .nav-links a:hover {
      color: var(--accent);
    }

    .has-dropdown { position: relative; }

    .dropdown {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      background: var(--bg-secondary);
      border: 1px solid rgba(168, 197, 240, 0.15);
      border-radius: 10px;
      min-width: 220px;
      box-shadow: 0 8px 24px rgba(27, 58, 107, 0.12);
      padding: 0.5rem 0;
      list-style: none;
      flex-direction: column;
      z-index: 200;
    }

    .has-dropdown:hover .dropdown { display: flex; }

    .dropdown li a {
      display: block;
      padding: 0.75rem 1.25rem;
      font-size: 0.9rem;
      color: var(--text);
    }

    .dropdown li a:hover {
      background: rgba(168, 197, 240, 0.08);
      color: var(--accent);
    }

    .nav-toggle {
      display: none;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
    }

    .nav-toggle span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--text);
    }

    .btn {
      display: inline-block;
      padding: 0.9rem 2rem;
      border-radius: 999px;
      font-weight: 700;
      font-size: 1rem;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .btn-primary {
      background: var(--primary);
      color: #FFFFFF;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(168, 197, 240, 0.25);
    }

    .hero {
      position: relative;
      background-image: url('/hero-bg.jpg');
      background-size: cover;
      background-position: right 50%;
      background-repeat: no-repeat;
    }

    .hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(10, 20, 45, 0.6) 0%, rgba(10, 20, 45, 0.75) 100%);
      z-index: 0;
    }

    .hero-inner {
      position: relative;
      z-index: 1;
      max-width: 800px;
      margin: 0 auto;
      padding: 8rem 5% 7rem;
      text-align: center;
      animation: fadeUp 0.8s ease both;
    }

    .hero-glow {
      display: none;
    }

    .eyebrow {
      color: var(--accent);
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-size: 0.85rem;
      margin-bottom: 1.25rem;
    }

    .hero h1 {
      font-size: clamp(2.2rem, 5vw, 3.6rem);
      font-weight: 800;
      line-height: 1.15;
      letter-spacing: -0.02em;
      margin-bottom: 1.5rem;
      color: #ffffff;
    }

    .hero h1 .highlight {
      color: var(--accent);
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .subheadline {
      font-size: 1.2rem;
      color: rgba(255, 255, 255, 0.85);
      margin-bottom: 0.75rem;
      line-height: 1.6;
    }

    .small-text {
      font-size: 0.95rem;
      color: rgba(26, 26, 46, 0.55);
      margin-bottom: 2rem;
    }

    section h2 {
      text-align: center;
      font-size: clamp(1.8rem, 4vw, 2.5rem);
      font-weight: 800;
      margin-bottom: 3rem;
      letter-spacing: -0.02em;
    }

    .our-work-section {
      padding: 5rem 5%;
      background: var(--bg);
      text-align: center;
    }

    .our-work-section h2 {
      color: var(--primary);
      margin-bottom: 3rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .our-work-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      max-width: 1100px;
      margin: 0 auto;
    }

    .work-item {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .work-item video {
      width: 100%;
      aspect-ratio: 9 / 16;
      object-fit: cover;
      border-radius: 12px;
      border: 1px solid rgba(168, 197, 240, 0.2);
    }

    .work-label {
      font-family: 'Monument Extended', sans-serif;
      font-weight: 800;
      font-size: 0.9rem;
      color: var(--primary);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      text-align: center;
    }

    .services-section, .results-section {
      padding: 5rem 5%;
    }

    .services-section {
      background: var(--primary);
      color: #FFFFFF;
    }

    .services-section h2 {
      color: var(--accent);
      margin-bottom: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      -webkit-text-stroke: 0.5px var(--accent);
    }

    .services-subheader {
      text-align: center;
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 1.4rem;
      color: rgba(255, 255, 255, 0.75);
      margin-top: -0.5rem;
      margin-bottom: 3rem;
    }

    .results-section {
      background: var(--bg-secondary);
    }

    .card-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
      max-width: 1100px;
      margin: 0 auto;
    }

    .card {
      background: var(--bg-secondary);
      border: 1px solid rgba(168, 197, 240, 0.1);
      border-radius: 16px;
      padding: 2.25rem;
      transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    }

    .card:hover {
      transform: translateY(-6px);
      border-color: rgba(168, 197, 240, 0.35);
      box-shadow: 0 16px 40px rgba(27, 58, 107, 0.35);
    }

    .card-icon {
      color: var(--accent);
      margin-bottom: 1rem;
    }

    .card h3 {
      font-size: 1.3rem;
      margin-bottom: 0.9rem;
      color: var(--accent);
    }

    .card p {
      font-weight: 600;
      line-height: 1.6;
      color: rgba(26, 26, 46, 0.85);
    }

    .stat-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      max-width: 1100px;
      margin: 0 auto;
    }

    .stat-card {
      background: var(--bg);
      border: 1px solid rgba(168, 197, 240, 0.15);
      border-radius: 16px;
      padding: 2.5rem;
      text-align: center;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
      display: flex;
      flex-direction: column;
      height: 100%;
    }

    .stat-label {
      margin-top: auto;
    }

    .stat-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 40px rgba(27, 58, 107, 0.35);
    }

    .stat-number {
      font-size: 2.5rem;
      font-weight: 800;
      color: var(--accent);
      margin-bottom: 0.25rem;
    }

    .stat-unit {
      font-size: 2.5rem;
      font-weight: 800;
      color: var(--accent);
      margin-bottom: 0.5rem;
    }

    .stat-label {
      color: rgba(26, 26, 46, 0.75);
      font-weight: 500;
    }

    .results-note {
      text-align: center;
      color: rgba(26, 26, 46, 0.5);
      font-size: 0.9rem;
      margin-top: 2rem;
    }

    .site-footer {
      padding: 1.5rem 5% 1.25rem;
      border-top: 1px solid rgba(168, 197, 240, 0.1);
      text-align: center;
    }

    .footer-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.75rem;
    }

    .footer-links {
      flex-wrap: wrap;
      justify-content: center;
      gap: 1.5rem 2rem;
    }

    .copyright {
      color: rgba(26, 26, 46, 0.4);
      font-size: 0.85rem;
    }

    @media (max-width: 768px) {
      .logo-img { height: 144px; }

      .nav-toggle { display: flex; }

      .nav-links {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: var(--bg-secondary);
        flex-direction: column;
        gap: 0;
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease;
      }

      .nav-links.open {
        max-height: 400px;
      }

      .nav-links li {
        width: 100%;
        border-top: 1px solid rgba(168, 197, 240, 0.1);
      }

      .nav-links a {
        display: block;
        padding: 1rem 5%;
      }

      .our-work-grid {
        grid-template-columns: 1fr;
      }

      .card-grid {
        grid-template-columns: 1fr;
      }

      .stat-grid {
        grid-template-columns: 1fr;
      }

      .hero-inner {
        padding: 4rem 5% 3rem;
      }
    }
  </style>
</body>
</html>
