---
const navLinks = [
  { href: "/services", label: "Services" },
  { href: "/portfolio", label: "Portfolio" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>Contact | Shockwave Studios</title>
  <meta name="description" content="Book a free 20 minute call with Shockwave Studios, a social media marketing agency in Melbourne, Florida." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="site-header">
    <a href="/" class="logo-link" aria-label="Shockwave Studios home">
      <img src="/shockwave-studios/logo.svg" alt="Shockwave Studios" class="logo-img" />
    </a>
    <nav class="nav">
      <button class="nav-toggle" aria-label="Toggle menu" onclick="document.querySelector('.nav-links').classList.toggle('open')">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav-links">
        {navLinks.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>
  </header>

  <main>
    <section class="contact-section">
      <div class="contact-hero">
        <h1>Let's Talk.</h1>
        <p class="subheadline">Book a free 20 minute call and let's figure out what social media can do for your business. No pressure, no commitment, just a real conversation.</p>
        <a href="https://calendly.com/shockwavestudios-co/30min" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-large">Book a Free Call</a>
        <div class="contact-details">
          <a href="tel:+13213911515" class="contact-detail">321-391-1515</a>
          <a href="mailto:shockwavestudios.co@gmail.com" class="contact-detail">shockwavestudios.co@gmail.com</a>
        </div>
        <div class="location-info">
          <p>Based in Melbourne, Florida</p>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <a href="/" class="logo-link" aria-label="Shockwave Studios home">
        <img src="/shockwave-studios/logo.svg" alt="Shockwave Studios" class="footer-logo-img" />
      </a>
      <ul class="nav-links footer-links">
        {navLinks.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>
    <p class="copyright">&copy; {new Date().getFullYear()} Shockwave Studios. Melbourne, Florida.</p>
  </footer>

  <style>
    :root {
      --bg: #F4F7FC;
      --bg-secondary: #FFFFFF;
      --accent: #A8C5F0;
      --primary: #1B3A6B;
      --secondary: #5B8FD4;
      --text: #1A1A2E;
    }

    @font-face {
      font-family: 'Monument Extended';
      src: url('/fonts/MonumentExtended-Regular.otf') format('opentype');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }

    @font-face {
      font-family: 'Monument Extended';
      src: url('/fonts/MonumentExtended-Ultrabold.otf') format('opentype');
      font-weight: 800;
      font-style: normal;
      font-display: swap;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      min-height: 100vh;
    }

    a { color: inherit; text-decoration: none; }

    h1, h2, h3 {
      font-family: 'Monument Extended', sans-serif;
      font-weight: 800;
      letter-spacing: 0.02em;
      color: #6B9FD4;
    }

    .eyebrow, .subheadline, .badge, .case-type, .comparison-group-label, th {
      font-family: 'Playfair Display', serif;
    }

    .site-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 5%;
      height: 88px;
      background: var(--bg);
      position: sticky;
      top: 0;
      z-index: 100;
      border-bottom: 1px solid rgba(168, 197, 240, 0.1);
    }

    .logo {
      font-size: 1.4rem;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    .logo-link {
      display: flex;
      align-items: center;
      height: 100%;
      overflow: hidden;
    }

    .logo-img {
      height: 192px;
      width: auto;
      display: block;
    }

    .footer-logo-img {
      height: 160px;
      width: auto;
      display: block;
    }

    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }

    .nav-links a {
      font-weight: 500;
      font-size: 0.95rem;
      transition: color 0.2s ease;
    }

    .nav-links a:hover { color: var(--accent); }

    .nav-toggle {
      display: none;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
    }

    .nav-toggle span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--text);
    }

    .btn {
      display: inline-block;
      padding: 0.9rem 2rem;
      border-radius: 999px;
      font-weight: 700;
      font-size: 1rem;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .btn-primary {
      background: var(--primary);
      color: #FFFFFF;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(168, 197, 240, 0.25);
    }

    .btn-large {
      padding: 1.25rem 3rem;
      font-size: 1.2rem;
      box-shadow: 0 0 0 0 rgba(168, 197, 240, 0.4);
      animation: pulse 2.5s ease-in-out infinite;
    }

    @keyframes pulse {
      0% { box-shadow: 0 0 0 0 rgba(168, 197, 240, 0.3); }
      70% { box-shadow: 0 0 0 16px rgba(168, 197, 240, 0); }
      100% { box-shadow: 0 0 0 0 rgba(168, 197, 240, 0); }
    }

    .contact-section {
      background: var(--bg-secondary);
    }

    .contact-hero {
      position: relative;
      max-width: 700px;
      margin: 0 auto;
      padding: 7rem 5% 6rem;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      animation: fadeUp 0.8s ease both;
    }

    .contact-hero::before {
      content: "";
      position: absolute;
      top: -10%;
      left: 50%;
      transform: translateX(-50%);
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(168, 197, 240, 0.14) 0%, rgba(168, 197, 240, 0) 70%);
      pointer-events: none;
      z-index: -1;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .contact-hero h1 {
      font-size: clamp(2.2rem, 5vw, 3.5rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      margin-bottom: 1.5rem;
    }

    .subheadline {
      font-size: 1.2rem;
      color: rgba(26, 26, 46, 0.8);
      line-height: 1.6;
      margin-bottom: 2.5rem;
    }

    .contact-details {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.6rem;
      margin-top: 2rem;
    }

    .contact-detail {
      font-size: 1.05rem;
      font-weight: 600;
      color: var(--secondary);
      transition: color 0.2s ease;
    }

    .contact-detail:hover {
      color: var(--primary);
    }

    .location-info {
      margin-top: 2.5rem;
    }

    .location-info p {
      color: rgba(26, 26, 46, 0.6);
      font-size: 0.95rem;
      margin-bottom: 0.3rem;
    }

    .site-footer {
      padding: 1.5rem 5% 1.25rem;
      border-top: 1px solid rgba(168, 197, 240, 0.1);
      text-align: center;
    }

    .footer-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.75rem;
    }

    .footer-links {
      flex-wrap: wrap;
      justify-content: center;
      gap: 1.5rem 2rem;
    }

    .copyright {
      color: rgba(26, 26, 46, 0.4);
      font-size: 0.85rem;
    }

    @media (max-width: 768px) {
      .logo-img { height: 144px; }

      .nav-toggle { display: flex; }

      .nav-links {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: var(--bg-secondary);
        flex-direction: column;
        gap: 0;
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease;
      }

      .nav-links.open { max-height: 400px; }

      .nav-links li {
        width: 100%;
        border-top: 1px solid rgba(168, 197, 240, 0.1);
      }

      .nav-links a {
        display: block;
        padding: 1rem 5%;
      }

      .contact-hero {
        padding: 5rem 5% 4rem;
      }
    }
  </style>
</body>
</html>
