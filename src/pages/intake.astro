---
import Layout from '../layouts/Layout.astro';
import BottomCTA from '../components/BottomCTA.astro';

const navLinks = [
  { href: "/services", label: "Services" },
  { href: "/portfolio", label: "Portfolio" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---
<Layout
  title="Client Intake | Shockwave Studios"
  description="Tell us about your business so we can build your custom social media strategy."
  noindex={true}
>
  <header class="site-header">
    <a href="/" class="logo-link" aria-label="Shockwave Studios home">
      <img src="/shockwave-studios/logo.svg" alt="Shockwave Studios" class="logo-img" />
    </a>
    <nav class="nav">
      <button class="nav-toggle" aria-label="Toggle menu" onclick="document.querySelector('.nav-links').classList.toggle('open')">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav-links">
        <li class="has-dropdown">
          <a href="/services">Services</a>
          <ul class="dropdown">
            <li><a href="/services">Social Media Management</a></li>
            <li><a href="/videography">Videography</a></li>
          </ul>
        </li>
        <li><a href="/portfolio">Portfolio</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <section class="intake-section">
      <div class="intake-hero">
        <h1>Let's Build Your Strategy.</h1>
        <p class="subheadline">This form takes about 10 minutes. Every answer you give shapes the custom strategy we build for your business, so the more detail you share, the better your strategy gets. There are no wrong answers.</p>
      </div>

      <div class="intake-form-wrap">
        <!--
          PASTE YOUR TALLY EMBED CODE BELOW.

          In Tally: open your form, click "Share", pick "Embed",
          copy the iframe snippet, and replace the placeholder
          <iframe> tag below with it. Keep it inside this
          .intake-form-wrap div so the styling stays intact.
        -->
        <iframe
          data-tally-src="https://tally.so/embed/815EYr?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
          loading="lazy"
          width="100%"
          height="3958"
          frameborder="0"
          marginheight="0"
          marginwidth="0"
          title="Shockwave Studios — Client Intake."
          class="intake-iframe"
        ></iframe>
        <!-- END TALLY EMBED -->
      </div>
    </section>

    <BottomCTA text="Questions before you fill it out? Let's talk first." />

    <script is:inline>
      var d=document,w="https://tally.so/widgets/embed.js",v=function(){"undefined"!=typeof Tally?Tally.loadEmbeds():d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach((function(e){e.src=e.dataset.tallySrc}))};if("undefined"!=typeof Tally)v();else if(d.querySelector('script[src="'+w+'"]')==null){var s=d.createElement("script");s.src=w,s.onload=v,s.onerror=v,d.body.appendChild(s);}
    </script>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <a href="/" class="logo-link" aria-label="Shockwave Studios home">
        <img src="/shockwave-studios/logo.svg" alt="Shockwave Studios" class="footer-logo-img" />
      </a>
      <ul class="nav-links footer-links">
        {navLinks.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>
    <p class="copyright">&copy; {new Date().getFullYear()} Shockwave Studios. Melbourne, Florida.</p>
  </footer>

  <style>
    :root {
      --bg: #F4F7FC;
      --bg-secondary: #FFFFFF;
      --accent: #A8C5F0;
      --primary: #1B3A6B;
      --secondary: #5B8FD4;
      --text: #1A1A2E;
    }

    @font-face {
      font-family: 'Monument Extended';
      src: url('/fonts/MonumentExtended-Regular.otf') format('opentype');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }

    @font-face {
      font-family: 'Monument Extended';
      src: url('/fonts/MonumentExtended-Ultrabold.otf') format('opentype');
      font-weight: 800;
      font-style: normal;
      font-display: swap;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      min-height: 100vh;
    }

    a { color: inherit; text-decoration: none; }

    h1, h2, h3 {
      font-family: 'Monument Extended', sans-serif;
      font-weight: 800;
      letter-spacing: 0.02em;
      color: #6B9FD4;
    }

    .eyebrow, .subheadline, .badge {
      font-family: 'Playfair Display', serif;
    }

    .site-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 5%;
      height: 88px;
      background: var(--bg);
      position: sticky;
      top: 0;
      z-index: 100;
      border-bottom: 1px solid rgba(168, 197, 240, 0.1);
    }

    .logo-link {
      display: flex;
      align-items: center;
      height: 100%;
      overflow: hidden;
    }

    .logo-img {
      height: 192px;
      width: auto;
      display: block;
    }

    .footer-logo-img {
      height: 160px;
      width: auto;
      display: block;
    }

    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }

    .nav-links a {
      font-weight: 500;
      font-size: 0.95rem;
      transition: color 0.2s ease;
    }

    .nav-links a:hover { color: var(--accent); }

    .has-dropdown { position: relative; }

    .dropdown {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      background: var(--bg-secondary);
      border: 1px solid rgba(168, 197, 240, 0.15);
      border-radius: 10px;
      min-width: 220px;
      box-shadow: 0 8px 24px rgba(27, 58, 107, 0.12);
      padding: 0.5rem 0;
      list-style: none;
      flex-direction: column;
      z-index: 200;
    }

    .has-dropdown:hover .dropdown { display: flex; }

    .dropdown li a {
      display: block;
      padding: 0.75rem 1.25rem;
      font-size: 0.9rem;
      color: var(--text);
    }

    .dropdown li a:hover {
      background: rgba(168, 197, 240, 0.08);
      color: var(--accent);
    }

    .nav-toggle {
      display: none;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
    }

    .nav-toggle span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--text);
    }

    .intake-section {
      background: var(--bg-secondary);
      padding-bottom: 5rem;
    }

    .intake-hero {
      position: relative;
      max-width: 700px;
      margin: 0 auto;
      padding: 6rem 5% 3rem;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      animation: fadeUp 0.8s ease both;
    }

    .intake-hero::before {
      content: "";
      position: absolute;
      top: -10%;
      left: 50%;
      transform: translateX(-50%);
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(168, 197, 240, 0.14) 0%, rgba(168, 197, 240, 0) 70%);
      pointer-events: none;
      z-index: -1;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .intake-hero h1 {
      font-size: clamp(2.2rem, 5vw, 3.5rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      margin-bottom: 1.5rem;
    }

    .subheadline {
      font-size: 1.2rem;
      color: rgba(26, 26, 46, 0.8);
      line-height: 1.6;
    }

    .intake-form-wrap {
      max-width: 800px;
      margin: 0 auto;
      padding: 0 5%;
    }

    .intake-iframe {
      display: block;
      width: 100%;
      border: none;
      border-radius: 12px;
      background: var(--bg);
    }

    .site-footer {
      padding: 1.5rem 5% 1.25rem;
      border-top: 1px solid rgba(168, 197, 240, 0.1);
      text-align: center;
    }

    .footer-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.75rem;
    }

    .footer-links {
      flex-wrap: wrap;
      justify-content: center;
      gap: 1.5rem 2rem;
    }

    .copyright {
      color: rgba(26, 26, 46, 0.4);
      font-size: 0.85rem;
    }

    @media (max-width: 768px) {
      .logo-img { height: 144px; }

      .nav-toggle { display: flex; }

      .nav-links {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: var(--bg-secondary);
        flex-direction: column;
        gap: 0;
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease;
      }

      .nav-links.open { max-height: 400px; }

      .nav-links li {
        width: 100%;
        border-top: 1px solid rgba(168, 197, 240, 0.1);
      }

      .nav-links a {
        display: block;
        padding: 1rem 5%;
      }

      .intake-hero {
        padding: 4rem 5% 2.5rem;
      }
    }
  </style>
</Layout>
