---
import Layout from '../layouts/Layout.astro';
import BottomCTA from '../components/BottomCTA.astro';
const navLinks = [
  { href: "/services", label: "Services" },
  { href: "/portfolio", label: "Portfolio" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

const plans = [
  {
    name: "BASIC",
    price: "$600",
    description: "For businesses that are ready to show up online but don't know where to start. We build your content strategy, film, edit, and post for you every month. You focus on running your business, we handle the rest.",
    features: [
      "Dedicated Content Vault",
      "Content pillars & strategy",
      "Scripting",
      "Scheduling & posting",
      "Profile optimization",
      "Instagram only",
      "1 filming session/mo, up to 2 hrs",
      "Basic editing",
      "Short-form video, 30-75 sec",
      "4 videos/mo",
      "1 custom video request/mo",
      "1 strategy call/mo",
    ],
  },
  {
    name: "STANDARD",
    price: "$1,250",
    featured: true,
    description: "For businesses that want to grow faster and start turning followers into actual leads. We expand to more platforms, go deeper on strategy, and set up automations that capture leads for you while you sleep.",
    features: [
      "Everything in Basic",
      "Instagram & TikTok",
      "Competitor & niche analysis",
      "2 filming sessions/mo, up to 2 hrs each",
      "Advanced editing",
      "Social Media Automation, 2 flows",
      "8 videos/mo",
      "2 custom video requests/mo",
      "1 strategy call/mo",
    ],
  },
  {
    name: "PREMIUM",
    price: "$2,750",
    description: "For businesses that are serious about owning their market online. Maximum content, maximum platforms, and full automation so your social media is working for you around the clock.",
    features: [
      "Everything in Standard",
      "Instagram, TikTok, YouTube & Facebook",
      "3 filming sessions/mo, up to 2 hrs each",
      "Advanced editing",
      "Social Media Automation, 4 flows",
      "16 videos/mo",
      "4 custom video requests/mo",
      "2 strategy calls/mo",
    ],
  },
];

const comparisonGroups = [
  {
    label: "Foundation",
    rows: [
      { feature: "Dedicated Content Vault", values: ["✓", "✓", "✓"] },
      { feature: "Scripting", values: ["✓", "✓", "✓"] },
      { feature: "Scheduling & posting", values: ["✓", "✓", "✓"] },
      { feature: "Profile optimization", values: ["✓", "✓", "✓"] },
    ],
  },
  {
    label: "Strategy",
    rows: [
      { feature: "Content pillars & strategy", values: ["✓", "✓", "✓"] },
      { feature: "Competitor & niche analysis", values: ["✗", "✓", "✓"] },
      { feature: "Strategy calls/mo", values: ["1", "1", "2"] },
    ],
  },
  {
    label: "Platforms",
    rows: [
      { feature: "Instagram", values: ["✓", "✓", "✓"] },
      { feature: "TikTok", values: ["✗", "✓", "✓"] },
      { feature: "YouTube & Facebook", values: ["✗", "✗", "✓"] },
    ],
  },
  {
    label: "Production",
    rows: [
      { feature: "Filming sessions/mo, up to 2 hrs each", values: ["1", "2", "3"] },
      { feature: "Short-form videos/mo (30-75 sec)", values: ["4", "8", "16"] },
      { feature: "Custom video requests/mo", values: ["1", "2", "4"] },
    ],
  },
  {
    label: "Editing",
    rows: [
      { feature: "Basic editing", values: ["✓", "✓", "✓"] },
      { feature: "Full & advanced editing", values: ["✗", "✓", "✓"] },
    ],
  },
  {
    label: "Automations",
    rows: [
      { feature: "Social Media Automation flows", values: ["—", "2", "4"] },
    ],
  },
];

const oneOffServices = [
  { name: "Video editing (single video)", price: "$120" },
  { name: "Filming", price: "$90/hr" },
  { name: "Social Media Automation flow setup (1 flow)", price: "$250" },
  { name: "Event package (filming + editing)", price: "Custom Quote" },
];

const addOns = [
  { name: "Extra filming session", price: "$60/hr" },
  { name: "Additional Social Media Automation flow", price: "$150" },
  { name: "Extra edited video", price: "$90" },
];

const monthlyPrices = [600, 1250, 2750];
const discountTiers = [
  { term: "3 Months", discount: 0.05 },
  { term: "6 Months", discount: 0.10 },
  { term: "12 Months", discount: 0.15 },
];
---
<Layout
  title="Services & Pricing | Shockwave Studios"
  description="Social media management, video production, and Social Media Automation packages from Shockwave Studios."
>
  <header class="site-header">
    <a href="/" class="logo-link" aria-label="Shockwave Studios home">
      <img src="/shockwave-studios/logo.svg" alt="Shockwave Studios" class="logo-img" />
    </a>
    <nav class="nav">
      <button class="nav-toggle" aria-label="Toggle menu" onclick="document.querySelector('.nav-links').classList.toggle('open')">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav-links">
        <li class="has-dropdown">
          <a href="/services">Services</a>
          <ul class="dropdown">
            <li><a href="/services">Social Media Management</a></li>
            <li><a href="/videography">Videography</a></li>
          </ul>
        </li>
        <li><a href="/portfolio">Portfolio</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <section class="page-hero">
      <div class="page-hero-inner">
        <h1>Social Media Management</h1>
        <p class="subheadline">Pick the plan that fits where your business is right now.</p>
      </div>
    </section>

    <section class="pricing-section pricing-section-navy">
      <div class="pricing-grid">
        {plans.map((plan, i) => (
          <div class={`pricing-card ${plan.featured ? "featured" : ""}`}>
            {plan.featured && <p class="badge">Most Popular</p>}
            <h3>{plan.name}</h3>
            <p class="price">{plan.price}<span>/mo</span></p>
            <p class="plan-description">{plan.description}</p>
            <div class="features-dropdown">
              <button class="features-toggle" onclick={`this.classList.toggle('open');this.nextElementSibling.classList.toggle('open')`}>
                See what's included
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <ul class="feature-list">
                {plan.features.map(f => <li>{f}</li>)}
              </ul>
            </div>
            <a href="https://calendly.com/shockwavestudios-co/30min" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Get Started</a>
          </div>
        ))}
      </div>
    </section>

    <section class="comparison-section">
      <div class="comparison-section-inner">
        <h2>Package Comparison</h2>
        <div class="comparison-wrap">
          <div class="comparison-table">
            <div class="comparison-row comparison-header">
              <div class="comparison-feature"></div>
              <div>BASIC</div>
              <div>STANDARD</div>
              <div>PREMIUM</div>
            </div>
            {comparisonGroups.map(group => (
              <>
                <div class="comparison-group-label">{group.label}</div>
                {group.rows.map((row, i) => (
                  <div class={`comparison-row ${i % 2 === 1 ? "alt" : ""}`}>
                    <div class="comparison-feature">{row.feature}</div>
                    {row.values.map(v => (
                      <div class={v === "✓" ? "check" : v === "✗" ? "cross" : "value"}>{v}</div>
                    ))}
                  </div>
                ))}
              </>
            ))}
          </div>
        </div>
      </div>
    </section>


    <section class="table-section">
      <div class="table-section-inner">
        <h2>Contract Discounts</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Commitment</th>
                <th>Discount</th>
                <th>Basic</th>
                <th>Standard</th>
                <th>Premium</th>
              </tr>
            </thead>
            <tbody>
              {discountTiers.map(tier => (
                <tr>
                  <td>{tier.term}</td>
                  <td>{Math.round(tier.discount * 100)}% off</td>
                  {monthlyPrices.map(price => (
                    <td>${Math.round(price * (1 - tier.discount)).toLocaleString()}/mo</td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
    <BottomCTA text="Not sure which plan is right for you? Let's figure it out together." />
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <a href="/" class="logo-link" aria-label="Shockwave Studios home">
        <img src="/shockwave-studios/logo.svg" alt="Shockwave Studios" class="footer-logo-img" />
      </a>
      <ul class="nav-links footer-links">
        {navLinks.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>
    <p class="copyright">&copy; {new Date().getFullYear()} Shockwave Studios. Melbourne, Florida.</p>
  </footer>

  <style>
    :root {
      --bg: #F4F7FC;
      --bg-secondary: #FFFFFF;
      --accent: #A8C5F0;
      --primary: #1B3A6B;
      --secondary: #5B8FD4;
      --text: #1A1A2E;
    }

    @font-face {
      font-family: 'Monument Extended';
      src: url('/fonts/MonumentExtended-Regular.otf') format('opentype');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }

    @font-face {
      font-family: 'Monument Extended';
      src: url('/fonts/MonumentExtended-Ultrabold.otf') format('opentype');
      font-weight: 800;
      font-style: normal;
      font-display: swap;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }

    a { color: inherit; text-decoration: none; }

    h1, h2, h3 {
      font-family: 'Monument Extended', sans-serif;
      font-weight: 800;
      letter-spacing: 0.02em;
      color: #6B9FD4;
    }

    .eyebrow, .subheadline, .badge, .case-type, .comparison-group-label, th {
      font-family: 'Playfair Display', serif;
    }

    .site-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 5%;
      height: 88px;
      background: var(--bg);
      position: sticky;
      top: 0;
      z-index: 100;
      border-bottom: 1px solid rgba(168, 197, 240, 0.1);
    }

    .logo {
      font-size: 1.4rem;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    .logo-link {
      display: flex;
      align-items: center;
      height: 100%;
      overflow: hidden;
    }

    .logo-img {
      height: 192px;
      width: auto;
      display: block;
    }

    .footer-logo-img {
      height: 160px;
      width: auto;
      display: block;
    }

    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }

    .nav-links {
      align-items: center;
    }

    .nav-links a {
      font-weight: 500;
      font-size: 0.95rem;
      transition: color 0.2s ease;
    }

    .nav-links a:hover { color: var(--accent); }

    .has-dropdown {
      position: relative;
    }

    .dropdown {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      background: var(--bg-secondary);
      border: 1px solid rgba(168, 197, 240, 0.15);
      border-radius: 10px;
      min-width: 220px;
      box-shadow: 0 8px 24px rgba(27, 58, 107, 0.12);
      padding: 0.5rem 0;
      list-style: none;
      flex-direction: column;
      z-index: 200;
    }

    .has-dropdown:hover .dropdown {
      display: flex;
    }

    .dropdown li a {
      display: block;
      padding: 0.75rem 1.25rem;
      font-size: 0.9rem;
      color: var(--text);
    }

    .dropdown li a:hover {
      background: rgba(168, 197, 240, 0.08);
      color: var(--accent);
    }

    .nav-toggle {
      display: none;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
    }

    .nav-toggle span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--text);
    }

    .btn {
      display: inline-block;
      padding: 0.9rem 2rem;
      border-radius: 999px;
      font-weight: 700;
      font-size: 1rem;
      text-align: center;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .btn-primary {
      background: var(--primary);
      color: #FFFFFF;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(168, 197, 240, 0.25);
    }

    .page-hero {
      background: var(--bg-secondary);
    }

    .page-hero-inner {
      max-width: 800px;
      margin: 0 auto;
      padding: 5rem 5% 3rem;
      text-align: center;
    }

    .page-hero h1 {
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      margin-bottom: 1rem;
    }

    .subheadline {
      font-size: 1.15rem;
      color: rgba(26, 26, 46, 0.75);
    }

    .pricing-section {
      padding: 2rem 5% 5rem;
    }

    .pricing-section-navy {
      background: var(--primary);
    }

    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      max-width: 1150px;
      margin: 0 auto 1rem;
      align-items: start;
      padding-top: 1rem;
    }

    .pricing-card {
      background: var(--bg-secondary);
      border: 1px solid rgba(168, 197, 240, 0.1);
      border-radius: 16px;
      padding: 2.25rem;
      display: flex;
      flex-direction: column;
      position: relative;
      transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    }

    .pricing-card:hover {
      transform: translateY(-6px);
      border-color: rgba(168, 197, 240, 0.35);
      box-shadow: 0 16px 40px rgba(27, 58, 107, 0.35);
    }

    .pricing-card.featured {
      border-color: var(--accent);
      box-shadow: 0 0 0 1px var(--accent), 0 20px 50px rgba(168, 197, 240, 0.12);
      transform: scale(1.03);
    }

    .pricing-card.featured:hover {
      transform: scale(1.03) translateY(-6px);
    }

    .badge {
      position: absolute;
      top: -0.85rem;
      left: 50%;
      transform: translateX(-50%);
      background: var(--accent);
      color: var(--bg);
      font-size: 0.75rem;
      font-weight: 800;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      padding: 0.35rem 1rem;
      border-radius: 999px;
    }

    .pricing-card h3 {
      font-size: 1.2rem;
      font-weight: 800;
      letter-spacing: 0.05em;
      color: var(--accent);
      margin-bottom: 0.75rem;
    }

    .price {
      font-size: 2.5rem;
      font-weight: 800;
      margin-bottom: 1.5rem;
    }

    .price span {
      font-size: 1rem;
      font-weight: 500;
      color: rgba(26, 26, 46, 0.6);
    }

    .plan-description {
      font-size: 0.9rem;
      line-height: 1.65;
      color: rgba(26, 26, 46, 0.7);
      margin-bottom: 1.25rem;
    }

    .features-dropdown {
      margin-bottom: 2rem;
      flex-grow: 1;
    }

    .features-toggle {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      background: none;
      border: none;
      cursor: pointer;
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--secondary);
      padding: 0;
      font-family: inherit;
      transition: color 0.2s ease;
    }

    .features-toggle:hover { color: var(--primary); }

    .features-toggle svg {
      transition: transform 0.25s ease;
      flex-shrink: 0;
    }

    .features-toggle.open svg {
      transform: rotate(180deg);
    }

    .feature-list {
      list-style: none;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease, margin-top 0.3s ease;
      margin-top: 0;
    }

    .feature-list.open {
      max-height: 600px;
      margin-top: 0.75rem;
    }

    .feature-list li {
      padding: 0.6rem 0;
      border-bottom: 1px solid rgba(168, 197, 240, 0.08);
      font-size: 0.92rem;
      color: rgba(26, 26, 46, 0.85);
      line-height: 1.4;
    }

    .feature-list li:last-child { border-bottom: none; }


    .comparison-section-inner {
      padding: 1rem 5% 3rem;
      max-width: 1000px;
      margin: 0 auto;
    }

    .comparison-section h2 {
      font-size: clamp(1.5rem, 4vw, 2rem);
      font-weight: 800;
      margin-bottom: 1.5rem;
      text-align: center;
    }

    .comparison-wrap {
      overflow-x: auto;
      border-radius: 12px;
      border: 1px solid rgba(168, 197, 240, 0.1);
    }

    .comparison-table {
      background: var(--bg-secondary);
      min-width: 560px;
    }

    .comparison-row {
      display: grid;
      grid-template-columns: 2.2fr 1fr 1fr 1fr;
      align-items: center;
      border-bottom: 1px solid rgba(168, 197, 240, 0.08);
    }

    .comparison-row.alt {
      background: rgba(168, 197, 240, 0.03);
    }

    .comparison-row > div {
      padding: 0.85rem 1rem;
      text-align: center;
      font-size: 0.92rem;
      font-weight: 700;
    }

    .comparison-feature {
      text-align: left !important;
      font-weight: 500 !important;
      color: rgba(26, 26, 46, 0.85);
    }

    .comparison-header {
      background: var(--bg);
      border-bottom: none;
    }

    .comparison-header > div {
      color: var(--secondary);
      letter-spacing: 0.04em;
      font-size: 1rem;
      font-weight: 800;
    }

    .comparison-group-label {
      background: rgba(168, 197, 240, 0.06);
      color: var(--accent);
      padding: 0.6rem 1rem;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .check { color: var(--secondary); }
    .cross { color: rgba(26, 26, 46, 0.25); }
    .value { color: rgba(26, 26, 46, 0.9); }

    .section-break {
      max-width: 700px;
      margin: 0 auto 2rem;
      text-align: center;
    }

    .section-break h2 {
      font-size: clamp(1.6rem, 4vw, 2.2rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      margin-bottom: 0.6rem;
    }

    .section-break p {
      color: rgba(255, 255, 255, 0.7);
      font-size: 1rem;
    }

    .table-section-inner {
      padding: 3rem 5%;
      max-width: 1000px;
      margin: 0 auto;
    }

    .table-section-navy {
      background: var(--primary);
    }

    .table-section-navy h2 {
      color: var(--accent);
    }

    .table-section h2 {
      font-size: clamp(1.5rem, 4vw, 2rem);
      font-weight: 800;
      margin-bottom: 1.5rem;
      text-align: center;
    }

    .table-wrap {
      overflow-x: auto;
      border-radius: 12px;
      border: 1px solid rgba(168, 197, 240, 0.1);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: var(--bg-secondary);
      min-width: 480px;
    }

    th, td {
      text-align: left;
      padding: 1rem 1.25rem;
      border-bottom: 1px solid rgba(168, 197, 240, 0.08);
      font-size: 0.95rem;
    }

    th {
      color: var(--accent);
      font-weight: 700;
      text-transform: uppercase;
      font-size: 0.8rem;
      letter-spacing: 0.05em;
    }

    tr:last-child td { border-bottom: none; }

    tbody tr {
      transition: background 0.2s ease;
    }

    tbody tr:hover {
      background: rgba(168, 197, 240, 0.05);
    }

    .video-table td:last-child {
      white-space: nowrap;
      font-weight: 700;
      color: var(--accent);
    }

    .video-cta-note {
      text-align: center;
      margin-top: 1.75rem;
      font-size: 1rem;
      color: rgba(255, 255, 255, 0.7);
    }

    .video-cta-note a {
      color: var(--accent);
      font-weight: 600;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .site-footer {
      padding: 1.5rem 5% 1.25rem;
      border-top: 1px solid rgba(168, 197, 240, 0.1);
      text-align: center;
    }

    .footer-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.75rem;
    }

    .footer-links {
      flex-wrap: wrap;
      justify-content: center;
      gap: 1.5rem 2rem;
    }

    .copyright {
      color: rgba(26, 26, 46, 0.4);
      font-size: 0.85rem;
    }

    @media (max-width: 768px) {
      .logo-img { height: 144px; }

      .nav-toggle { display: flex; }

      .nav-links {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: var(--bg-secondary);
        flex-direction: column;
        gap: 0;
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease;
      }

      .nav-links.open { max-height: 400px; }

      .nav-links li {
        width: 100%;
        border-top: 1px solid rgba(168, 197, 240, 0.1);
      }

      .nav-links a {
        display: block;
        padding: 1rem 5%;
      }

      .pricing-grid { grid-template-columns: 1fr; }

      .has-dropdown .dropdown {
        display: flex;
        position: static;
        box-shadow: none;
        border: none;
        border-radius: 0;
        background: rgba(168, 197, 240, 0.05);
        padding: 0;
        min-width: unset;
      }

      .dropdown li a {
        padding-left: 10%;
      }
    }
  </style>
</Layout>
